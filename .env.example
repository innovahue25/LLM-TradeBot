# =====================================================
#AI Trader environment variable configuration
# =====================================================
# 
# Instructions for use:
# 1. Copy this file to .env
# 2. Fill in your real API key
# 3. .env files will be ignored by .gitignore and will not be uploaded to git
#
# =====================================================

# -----------------------------------------------------
# Binance API configuration
# -----------------------------------------------------
# Obtain address: https://www.binance.com/zh-CN/my/settings/api-management
# Testnet address: https://testnet.binancefuture.com
# 
# ⚠️ Important: It is recommended to use the testnet first!
# 
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# -----------------------------------------------------
# LLM API configuration (supports multiple providers)
# -----------------------------------------------------
# Just configure the API Key of the provider you use
# Select which provider to use via the LLM_PROVIDER variable

# LLM provider selection (default: deepseek)
# Optional: deepseek, openai, claude, qwen, gemini, kimi, minimax, glm
LLM_PROVIDER=deepseek

# DeepSeek (default recommended -low cost and high performance)
# Obtain address: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI (optional)
# Obtain address: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Claude /Anthropic (optional)
# Obtain address: https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# Tongyi Qianwen Qwen (optional)
# Obtain address: https://dashscope.console.aliyun.com
QWEN_API_KEY=your_qwen_api_key_here

# Google Gemini (optional)
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

#Kimi /Moonshot (optional)
# Obtain address: https://platform.moonshot.ai
KIMI_API_KEY=your_kimi_api_key_here

# MiniMax (optional)
# Obtain address: https://platform.minimax.io
MINIMAX_API_KEY=your_minimax_api_key_here

#GLM /智典 (optional)
# Obtain address: https://open.bigmodel.cn
GLM_API_KEY=your_glm_api_key_here

# Custom Base URL (optional -for proxy service)
LLM_BASE_URL=

# -----------------------------------------------------
# Redis configuration (optional)
# -----------------------------------------------------
# If you need to use Redis cache, please configure the following parameters
#
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------
# Quant Data API configuration (nofxaios)
# -----------------------------------------------------
# Used to obtain institutional capital flows, OI data, etc.
#
QUANT_AUTH_TOKEN=cm_568c67eae410d912c54c

# -----------------------------------------------------
#Other optional configurations
# -----------------------------------------------------
#LOG_LEVEL=INFO
# TRADING_MODE=testnet # testnet or live

# Transaction currency configuration (Railway deployment uses AUTO3 by default)
# AUTO3 = AI500 intelligent currency selection (automatically selects the best 2 currencies every 12 hours)
# AI500_TOP5 = AI500 Top 5 currencies
# Manually specify: BTCUSDT, ETHUSDT, SOLUSDT
TRADING_SYMBOLS=AUTO3

# -----------------------------------------------------
# Web Dashboard security configuration
# -----------------------------------------------------
#Set web page access password (default: admin)
WEB_PASSWORD=admin

# Database Configuration (Railway will auto-provide DATABASE_URL)
# For local development, leave empty to use SQLite
# DATABASE_URL=postgresql://user:password@localhost:5432/tradebot

# WebSocket Configuration
# Set to 'false' to disable WebSocket and use REST API only
# USE_WEBSOCKET=true
